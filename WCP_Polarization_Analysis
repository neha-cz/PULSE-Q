        "\n",
        "# ==========================================\n",
        "# 11. WIGNER SNAPSHOT (Bosonic Mode)\n",
        "# ==========================================\n",
        "\n",
        "center_idx = np.argmin(np.abs(tlist - pulse_center))\n",
        "rho_peak = result.states[center_idx].ptrace(0)\n",
        "\n",
        "xvec = np.linspace(-3, 3, 200)\n",
        "W = qt.wigner(rho_peak, xvec, xvec)\n",
        "\n",
