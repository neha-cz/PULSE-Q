        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import qutip as qt\n",
        "from qutip import mesolve, Bloch\n",
        "import matplotlib.gridspec as gridspec"
      ],
      "metadata": {
        "id": "wzS_Vgk3WiiK"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 1. PHYSICAL PARAMETERS (LEO Environment)\n",
        "# ==========================================\n",
        "temperature_kelvin = 403\n",
        "\n",
        "# Photon loss\n",
        "lifetime_ns = 1.0\n",
        "gamma_decay = 1.0 / lifetime_ns\n",
        "\n",
        "# Dephasing\n",
        "gamma_dephase_thermal = 0.05 * (temperature_kelvin / 4.0)**2\n",
        "gamma_dephase_radiation = 0.2\n",
        "gamma_total_dephase = gamma_dephase_thermal + gamma_dephase_radiation\n",
        "\n",
        "# Stray light pumping\n",
        "gamma_stray_light = 0.15 * gamma_decay\n",
        "\n",
        "# Weak coherent pulse strength\n",
        "target_mu = 0.5\n",
        "target_alpha = np.sqrt(target_mu)"
      ],
      "metadata": {
        "id": "JTQ-uM1qG5T2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 2. LASER PULSE SHAPE\n",
        "# ==========================================\n",
        "period_ns = 10.0\n",
        "pulse_width = 0.2\n",
        "pulse_center = 2.0\n",
        "drive_amp = target_alpha / (pulse_width * np.sqrt(2 * np.pi))\n",
        "\n",
        "def laser_pulse_shape(t, args):\n",
        "    return np.exp(-((t - args['center'])**2) / (2 * args['width']**2))\n",
        "\n",
        "pulse_args = {'center': pulse_center, 'width': pulse_width}"
      ],
      "metadata": {
        "id": "etFiry2zG7dK"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 3. HILBERT SPACES\n",
        "# ==========================================\n",
        "\n",
        "# Fock space\n",
        "N = 15\n",
        "a = qt.destroy(N)\n",
        "n_op = a.dag() * a\n",
        "Id_fock = qt.qeye(N)\n",
        "\n",
        "# Polarization qubit space\n",
        "sx = qt.sigmax()\n",
        "sy = qt.sigmay()\n",
        "sz = qt.sigmaz()\n",
        "Id_pol = qt.qeye(2)\n",
        "\n",
        "# Tensor identities\n",
        "Id_total = qt.tensor(Id_fock, Id_pol)"
      ],
      "metadata": {
        "id": "cW_24ulmG9mq"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 4. HAMILTONIAN (Fock + Polarization)\n",
        "# ==========================================\n",
        "\n",
        "# Coherent drive on Fock space only\n",
        "H_drive_fock = 1j * drive_amp * (a.dag() - a)\n",
        "\n",
        "H_total = [\n",
        "    qt.tensor(0 * n_op, Id_pol),\n",
        "    [qt.tensor(H_drive_fock, Id_pol), laser_pulse_shape]\n",
        "]"
      ],
      "metadata": {
        "id": "DPVWwuETG_fD"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# ==========================================\n",
        "# 5. COLLAPSE OPERATORS (Noise)\n",
        "# ==========================================\n",
        "\n",
        "c_ops = []\n",
        "\n",
        "# Photon loss\n",
        "c_ops.append(np.sqrt(gamma_decay) * qt.tensor(a, Id_pol))\n",
        "\n",
        "# Phase dephasing\n",
        "c_ops.append(np.sqrt(gamma_total_dephase) * qt.tensor(n_op, Id_pol))\n",
        "\n",
        "# Stray light pumping\n",
        "c_ops.append(np.sqrt(gamma_stray_light) * qt.tensor(a.dag(), Id_pol))"
      ],
      "metadata": {
        "id": "VrKRCkI5HBm9"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 6. INITIAL STATE\n",
        "# ==========================================\n",
        "\n",
        "# Vacuum in Fock\n",
        "psi_fock = qt.basis(N, 0)\n",
        "\n",
        "# BB84 polarization example: |+> state\n",
        "psi_pol = (qt.basis(2,0) + qt.basis(2,1)).unit()\n",
        "\n",
        "# Combined initial state\n",
        "psi0 = qt.tensor(psi_fock, psi_pol)\n"
      ],
      "metadata": {
        "id": "gdKeY1XvHDgA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 7. MASTER EQUATION SOLVE\n",
        "# ==========================================\n",
        "\n",
        "tlist = np.linspace(0, 10, 500)\n",
        "\n",
        "result = mesolve(H_total, psi0, tlist, c_ops, [], args=pulse_args)\n",
        "\n",
        "rho_final = result.states[-1]"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "OO1vNqZBHFkM",
        "outputId": "a45b3d7a-05c5-4f8c-c5fd-47e115dfcb00"
      },
