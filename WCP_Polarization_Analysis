      "source": [
        "# ==========================================\n",
        "# 10. BLOCH SPHERE VISUALIZATION\n",
        "# ==========================================\n",
        "\n",
        "bloch_ideal = [\n",
        "    qt.expect(sx, psi_pol),\n",
        "    qt.expect(sy, psi_pol),\n",
        "    qt.expect(sz, psi_pol)\n",
        "]\n",
        "\n",
        "bloch_final = [\n",
        "    qt.expect(sx, rho_pol_final),\n",
        "    qt.expect(sy, rho_pol_final),\n",
        "    qt.expect(sz, rho_pol_final)\n",
        "]\n",
        "\n",
        "b = Bloch()\n",
        "b.vector_color = ['b','r']\n",
        "b.add_vectors(bloch_ideal)\n",
        "b.add_vectors(bloch_final)\n",
        "print(bloch_ideal)\n",
        "print(bloch_final)\n",
        "b.title = [\"Blue = Original\", \"Red = After LEO Drift\"]\n",
        "b.show()"
