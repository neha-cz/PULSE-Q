            "  warnings.warn(\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 8. POLARIZATION ROTATIONS (Faraday + Wigner)\n",
        "# ==========================================\n",
        "\n",
        "# Example LEO rotation angles (radians)\n",
        "theta_faraday = 0.15\n",
        "theta_wigner = 0.05 # make this smaller\n",
        "\n",
        "U_faraday = (-1j * theta_faraday/2 * sz).expm()\n",
        "U_wigner = (-1j * theta_wigner/2 * sy).expm()\n",
        "\n",
        "U_pol = U_wigner * U_faraday\n",
        "U_total = qt.tensor(Id_fock, U_pol)\n",
        "\n",
        "# Apply rotation to full state\n",
        "rho_rotated = U_total * rho_final * U_total.dag()\n",
        "\n",
        "# Extract polarization reduced density matrix\n",
        "rho_pol_final = rho_rotated.ptrace(1)"
      ],
      "metadata": {
        "id": "YGT53jx8HHwW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ==========================================\n",
        "# 9. METRICS\n",
        "# ==========================================\n",
        "\n",
        "# Fock reduced state\n",
        "rho_fock_final = rho_rotated.ptrace(0)\n",
        "\n",
        "# Ideal coherent state\n",
        "ideal_fock = qt.coherent(N, target_alpha)\n",
        "\n",
        "fidelity_fock = qt.fidelity(rho_fock_final, ideal_fock)\n",
        "purity_fock = (rho_fock_final * rho_fock_final).tr().real\n",
        "\n",
        "# Polarization metrics\n",
        "fidelity_pol = qt.fidelity(rho_pol_final, psi_pol)\n",
        "purity_pol = (rho_pol_final * rho_pol_final).tr().real\n",
        "\n",
        "print(\"===== CHANNEL RESULTS =====\")\n",
        "print(f\"Fock Fidelity: {fidelity_fock:.4f}\")\n",
        "print(f\"Fock Purity: {purity_fock:.4f}\")\n",
        "print(f\"Polarization Fidelity: {fidelity_pol:.4f}\")\n",
        "print(f\"Polarization Purity: {purity_pol:.4f}\")\n"
      ],
      "metadata": {
